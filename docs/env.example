# ============================================================
# Knowledge Hub — Example Environment Variables
# Copy to .env at project root and fill in real values.
# Never commit .env.
# ============================================================

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/knowledge_hub

# ------------------------------------------------------------
# Valkey / Redis (rate limiting)
# ------------------------------------------------------------
VALKEY_URL=valkey://localhost:6379

# ------------------------------------------------------------
# Ollama — embedding always local, LLM can be remote
# OLLAMA_EMBED_URL: local instance for dense embedding (do not change to remote)
# OLLAMA_LLM_URL:   can point to a remote GPU server when LLM_PROVIDER=ollama
# ------------------------------------------------------------
OLLAMA_EMBED_URL=http://localhost:11434
OLLAMA_LLM_URL=http://localhost:11434

# ------------------------------------------------------------
# Embedding model (runs on OLLAMA_EMBED_URL)
# POC: zylonai/multilingual-e5-large (F16, MIT, digest c1522b1c...d76b — pinned 2026-04-28)
# Rollback path: EMBEDDING_MODEL=mxbai-embed-large
# ------------------------------------------------------------
EMBEDDING_MODEL=zylonai/multilingual-e5-large
OLLAMA_MAX_EMBED_CHARS=1400

# ------------------------------------------------------------
# LLM provider: ollama | openai | claude
# ------------------------------------------------------------
LLM_PROVIDER=ollama

# Ollama LLM (used when LLM_PROVIDER=ollama)
LLM_MODEL=llama3
LLM_TIMEOUT_S=5.0

# OpenAI (used when LLM_PROVIDER=openai)
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=                        # leave unset for OpenAI; set for OpenRouter:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# (when using OpenRouter, set OPENAI_API_KEY to your OpenRouter key)

# Anthropic Claude (used when LLM_PROVIDER=claude)
# LLM_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------
# RAG hybrid search weights (must sum to 1.0)
# ------------------------------------------------------------
RAG_DENSE_WEIGHT=0.7
RAG_BM25_WEIGHT=0.3

# ------------------------------------------------------------
# RAG chunking
# ------------------------------------------------------------
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ------------------------------------------------------------
# Document ingestion
# ------------------------------------------------------------
MAX_DOC_CHARS=100000

# ------------------------------------------------------------
# Auth — OIDC (required for human user login)
# ------------------------------------------------------------
OIDC_ISSUER=https://your-idp.example.com
OIDC_AUDIENCE=knowledge-hub
OIDC_JWKS_URI=https://your-idp.example.com/.well-known/jwks.json
OIDC_GROUPS_CLAIM=groups
OIDC_EMAIL_CLAIM=email
OIDC_NAME_CLAIM=name
OIDC_JWKS_CACHE_TTL=3600

# ------------------------------------------------------------
# Dev overrides (increase timeouts for slow local models)
# ------------------------------------------------------------
# RETRIEVAL_TIMEOUT_OVERRIDE=3.0
# LLM_TIMEOUT_OVERRIDE=5.0
