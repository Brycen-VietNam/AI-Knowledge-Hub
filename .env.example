# Copy to .env and fill in values
# Never commit .env to git

# PostgreSQL credentials (used by docker-compose.yml)
POSTGRES_USER=kh_user
POSTGRES_PASSWORD=change_me_in_dot_env

# PostgreSQL connection (asyncpg driver — D03)
DATABASE_URL=postgresql+asyncpg://kh_user:change_me_in_dot_env@localhost:5432/knowledge_hub

# Valkey / Redis (C016)
REDIS_URL=redis://localhost:6379/0

# LLM Provider (C015)
LLM_PROVIDER=ollama
