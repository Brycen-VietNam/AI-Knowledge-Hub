# Copy to .env and fill in values
# Never commit .env to git

# PostgreSQL credentials (used by docker-compose.yml)
POSTGRES_USER=kh_user
POSTGRES_PASSWORD=change_me_in_dot_env

# PostgreSQL connection (asyncpg driver — D03)
DATABASE_URL=postgresql+asyncpg://kh_user:change_me_in_dot_env@localhost:5432/knowledge_hub

# Valkey / Redis (C016)
REDIS_URL=redis://localhost:6379/0

# LLM Provider (C015)
LLM_PROVIDER=ollama
OLLAMA_LLM_URL=http://localhost:11434

# Ollama — embedding always local, LLM can be remote
OLLAMA_EMBED_URL=http://localhost:11434
EMBEDDING_MODEL=mxbai-embed-large

LLM_MODEL=openai/gpt-oss-120b:free
OPENAI_API_KEY=sk-or-v1-ca
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# OIDC (required by auth module — set real values for SSO login)
OIDC_ISSUER=https://placeholder.example.com
OIDC_AUDIENCE=knowledge-hub
OIDC_JWKS_URI=https://placeholder.example.com/.well-known/jwks.json

AUTH_SECRET_KEY=<generate-with-openssl-rand-hex-32>
AUTH_TOKEN_EXPIRE_MINUTES=60