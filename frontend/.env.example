# frontend/.env.example
# Task: T003 (S005) — document required VITE_ environment variables
#
# Copy this file to .env and fill in values before starting the dev server:
#   cp .env.example .env
#
# NOTE: Vite bakes VITE_* variables into the bundle at BUILD TIME.
# For Docker deployments, set these as build args (see docker-compose.yml).

# Backend API base URL (no trailing slash)
# Points to the FastAPI app — local dev server or Docker container
VITE_API_BASE_URL=http://localhost:8000
